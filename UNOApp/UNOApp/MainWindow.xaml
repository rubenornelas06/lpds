<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UNO - Mesa de Jogo" Height="600" Width="800" Background="#2E8B57" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <GroupBox Header="Bot 1" Margin="20,10,20,10" Padding="10" Background="White" Width="120">
                <StackPanel>
                    <TextBlock Text="👤" FontSize="30" HorizontalAlignment="Center"/>
                    <TextBlock Text="7 Cartas" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>
            <GroupBox Header="Bot 2" Margin="20,10,20,10" Padding="10" Background="White" Width="120">
                <StackPanel>
                    <TextBlock Text="👤" FontSize="30" HorizontalAlignment="Center"/>
                    <TextBlock Text="7 Cartas" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,5,0,0"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <Button Grid.Row="0" Content="Suspender Jogo" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15" Padding="10,5"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">

            <StackPanel Margin="20">
                <TextBlock Text="Baralho" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                <Button Content="UNO&#x0a;(Comprar)" Width="90" Height="130" Background="#111111" Foreground="White" FontWeight="Bold" FontSize="16"/>
            </StackPanel>

            <StackPanel Margin="20">
                <TextBlock Text="Descarte" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                <Button Content="5&#x0a;Verde" Width="90" Height="130" Background="#32CD32" Foreground="White" FontSize="20" FontWeight="Bold"/>
            </StackPanel>

        </StackPanel>

        <Button Grid.Row="1" Content="GRITAR UNO!" Width="140" Height="50" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="30" Background="#FF4500" Foreground="White" FontWeight="Bold" FontSize="16"/>

        <GroupBox Grid.Row="2" Header="A Minha Mão (Ruben)" Margin="20,10,20,20" Padding="10" Background="White">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Verde 2" Width="80" Height="110" Margin="5" Background="#90EE90" FontSize="14"/>
                <Button Content="Azul 9" Width="80" Height="110" Margin="5" Background="#87CEFA" FontSize="14"/>
                <Button Content="Verm. +2" Width="80" Height="110" Margin="5" Background="#F08080" FontSize="14"/>
                <Button Content="Amarelo 4" Width="80" Height="110" Margin="5" Background="#FFFACD" FontSize="14"/>
                <Button Content="Coringa" Width="80" Height="110" Margin="5" Background="#333333" Foreground="White" FontSize="14"/>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>